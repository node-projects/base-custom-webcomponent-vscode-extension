{
  "name": "helloworld",
  "displayName": "New Extension",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:helloworld.helloWorld"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css",
          "source.css": "css"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html.string.injection",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-string-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html.style.injection",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-style-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html-svg",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-svg.json",
        "embeddedLanguages": {
          "meta.embedded.block.svg": "xml"
        }
      },
      {
        "scopeName": "source.css.styled",
        "path": "./src/document/syntaxes/vscode-styled-components/css.styled.json"
      },
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.js.jsx",
          "source.tsx"
        ],
        "scopeName": "styled",
        "path": "./src/document/syntaxes/vscode-styled-components/styled-components.json",
        "embeddedLanguages": {
          "source.css.scss": "css",
          "meta.embedded.line.ts": "typescript"
        }
      }
    ],
    "commands": [
      {
        "command": "helloworld.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "domutils": "^3.2.2",
    "html-dom-parser": "^5.1.8",
    "html5parser": "^2.0.2",
    "htmlparser2": "^10.1.0",
    "jsdom": "^28.0.0",
    "lit-analyzer": "^2.0.3",
    "node-html-parser": "^7.0.2",
    "parse5": "^8.0.0",
    "performant-array-to-tree": "^1.11.0",
    "tree-model": "^1.0.7",
    "vscode-css-languageservice": "^6.3.9",
    "vscode-html-languageservice": "^5.6.1"
  }
}
