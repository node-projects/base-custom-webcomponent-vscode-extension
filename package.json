{
  "name": "html-css-template-validator",
  "displayName": "Html-Css Template Validator",
  "description": "Validates HTML/CSS templates and custom tags/attributes.",
  "version": "0.0.1",
  "publisher": "JOSEmmanuel",
  "license": "MIT",
  "keywords": [
    "html",
    "css",
    "validator",
    "lint"
  ],
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/node-projects/base-custom-webcomponent-vscode-extension"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Html-Css Template Validator",
      "properties": {
        "html-css-template-validator.customTags": {
          "type": "array",
          "default": [],
          "scope": "resource",
          "description": "Custom tags + attributes (leer = keine Custom-Regeln).",
          "items": {
            "type": "object",
            "required": [
              "name",
              "attributes"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "default": ""
              },
              "attributes": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "object",
                  "required": [
                    "name"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string",
                      "default": ""
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css",
          "source.css": "css"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html.string.injection",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-string-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html.style.injection",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-style-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html.basic"
        ],
        "scopeName": "inline.lit-html-svg",
        "path": "./src/document/syntaxes/vscode-lit-html/lit-html-svg.json",
        "embeddedLanguages": {
          "meta.embedded.block.svg": "xml"
        }
      },
      {
        "scopeName": "source.css.styled",
        "path": "./src/document/syntaxes/vscode-styled-components/css.styled.json"
      },
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.js.jsx",
          "source.tsx"
        ],
        "scopeName": "styled",
        "path": "./src/document/syntaxes/vscode-styled-components/styled-components.json",
        "embeddedLanguages": {
          "source.css.scss": "css",
          "meta.embedded.line.ts": "typescript"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./ --noEmit false",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "node esbuild.config.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "lit-analyzer": "^2.0.3",
    "node-html-parser": "^7.0.2",
    "parse5": "7.3.0",
    "vscode-css-languageservice": "^6.3.9",
    "vscode-html-languageservice": "^5.6.1"
  }
}
